# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=b2management
DB_PASSWORD=your_password_here
DB_NAME=b2management
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# Server Configuration
SERVER_PORT=8080

# AWS/Backblaze Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_ENDPOINT=https://s3.us-west-002.backblazeb2.com
AWS_REGION=us-west-002

# Analytics Configuration
ANALYTICS_INTERVAL=4h
ANALYTICS_WORKERS=4
ENABLE_INDEXING=true
INDEXING_EXCLUDE_BUCKETS=bucket1,bucket2,bucket3

# Execution Logs Configuration
LOG_RETENTION_DAYS=7
LOG_CLEANUP_INTERVAL=24h
